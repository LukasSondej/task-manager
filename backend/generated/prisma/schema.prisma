generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int     @id @default(autoincrement())
  email        String  @unique
  password     String
  refreshToken String?
  task         Task[]
}

model Task {
  id          Int     @id @default(autoincrement())
  title       String
  description String?
  status      String  @default("TODO")
  userId      Int
  user        User    @relation(fields: [userId], references: [id])
}
